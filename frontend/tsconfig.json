/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@mereka/core": [
        "./projects/mereka/core/src/public-api.ts"
      ],
      "@mereka/models": [
        "./projects/mereka/models/src/public-api.ts"
      ],
      "@mereka/ui": [
        "./projects/mereka/ui/src/public-api.ts"
      ],
      "@mereka/ui/*": [
        "./projects/mereka/ui/src/lib/components/*"
      ],
      "@mereka/environments": [
        "./projects/mereka/environments/common-environment.ts"
      ]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "moduleResolution": "bundler"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/auth/tsconfig.app.json"
    },
    {
      "path": "./projects/auth/tsconfig.spec.json"
    },
    {
      "path": "./projects/web/tsconfig.app.json"
    },
    {
      "path": "./projects/web/tsconfig.server.json"
    },
    {
      "path": "./projects/web/tsconfig.spec.json"
    },
    {
      "path": "./projects/app/tsconfig.app.json"
    },
    {
      "path": "./projects/app/tsconfig.spec.json"
    },
    {
      "path": "./projects/checkout/tsconfig.app.json"
    },
    {
      "path": "./projects/checkout/tsconfig.spec.json"
    },
    {
      "path": "./projects/admin/tsconfig.app.json"
    },
    {
      "path": "./projects/admin/tsconfig.spec.json"
    },
    {
      "path": "./projects/mereka/ui/tsconfig.lib.json"
    },
    {
      "path": "./projects/mereka/ui/tsconfig.spec.json"
    },
    {
      "path": "./projects/mereka/core/tsconfig.lib.json"
    },
    {
      "path": "./projects/mereka/core/tsconfig.spec.json"
    },
    {
      "path": "./projects/mereka/models/tsconfig.lib.json"
    },
    {
      "path": "./projects/mereka/models/tsconfig.spec.json"
    }
  ]
}
