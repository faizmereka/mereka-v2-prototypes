{
  "name": "mereka-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "dev": "ng serve web --port 4200 --poll 2000 & ng serve app --port 4202 --poll 2000 & ng serve auth --port 4201 --poll 2000 & ng serve checkout --port 4203 --poll 2000 & ng serve admin --port 4204 --poll 2000",
    "dev:web": "ng serve web --port 4200 --poll 2000",
    "dev:app": "ng serve app --port 4202 --poll 2000",
    "dev:auth": "ng serve auth --port 4201 --poll 2000",
    "dev:admin": "ng serve admin --port 4204 --poll 2000",
    "dev:checkout": "ng serve checkout --port 4203 --poll 2000",
    "dev:web+auth": "ng serve web --port 4200 --poll 2000 & ng serve auth --port 4201 --poll 2000",
    "dev:app+auth": "ng serve app --port 4202 --poll 2000 & ng serve auth --port 4201 --poll 2000",
    "build:libs": "ng build @mereka/models && ng build @mereka/core && ng build @mereka/ui",
    "build:prod": "npm run build:libs && ng build --configuration=production",
    "build:web": "ng build web --configuration=production",
    "build:app": "ng build app --configuration=production",
    "build:auth": "ng build auth --configuration=production",
    "build:admin": "ng build admin --configuration=production",
    "build:checkout": "ng build checkout --configuration=production",
    "deploy:web": "bash k8s/deploy-web.sh",
    "deploy:app": "bash k8s/deploy-app.sh",
    "deploy:auth": "bash k8s/deploy-auth.sh",
    "deploy:admin": "bash k8s/deploy-admin.sh",
    "deploy:status": "kubectl get pods -n mereka-backend -l 'app in (mereka-web,mereka-app,mereka-auth,mereka-admin)'",
    "deploy:logs:web": "kubectl logs -n mereka-backend -l app=mereka-web --tail=50",
    "deploy:logs:app": "kubectl logs -n mereka-backend -l app=mereka-app --tail=50",
    "deploy:logs:auth": "kubectl logs -n mereka-backend -l app=mereka-auth --tail=50",
    "deploy:logs:admin": "kubectl logs -n mereka-backend -l app=mereka-admin --tail=50",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:web": "playwright test --project=web",
    "e2e:app": "playwright test --project=app",
    "e2e:reviews": "playwright test e2e/tests/reviews/",
    "e2e:report": "playwright show-report e2e/reports"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "^21.1.3",
    "@angular/cdk": "^21.0.2",
    "@angular/common": "^21.1.3",
    "@angular/compiler": "^21.1.3",
    "@angular/core": "^21.1.3",
    "@angular/forms": "^21.1.3",
    "@angular/material": "^21.1.3",
    "@angular/platform-browser": "^21.1.3",
    "@angular/platform-server": "^21.1.3",
    "@angular/router": "^21.1.3",
    "@stripe/stripe-js": "^8.7.0",
    "dayjs": "^1.11.19",
    "express": "^4.18.2",
    "firebase": "^12.6.0",
    "lottie-web": "^5.13.0",
    "ngx-lottie": "^20.0.0",
    "ngx-masonry": "^14.0.1",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "swiper": "^12.1.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@angular/build": "^21.0.2",
    "@angular/cli": "^21.0.2",
    "@angular/compiler-cli": "^21.1.3",
    "@angular/ssr": "^21.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^27.1.0",
    "ng-packagr": "^21.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
