### 5. Get Experience by ID or Slug (includes experienceEvents)
# GET /experiences/:idOrSlug
# Automatically detects if param is ObjectId or slug
# Works with BOTH:
# - MongoDB ObjectId (24 hex characters): GET /experiences/6911c9666705fd8f6e1acda7
# - Slug string: GET /experiences/test-event-gen-debug-001
#
# Response includes:
# - Experience details (all fields)
# - experienceEvents[] - Array of generated events (sorted by startTime)
# - eventStats - Summary { total, active, cancelled, locked }

# Example with ID:
GET {{baseUrl}}/experiences/{{experienceId}}

###

# Example with Slug:
GET {{baseUrl}}/experiences/test-event-gen-debug-001

###

### 6. Check Slug Availability
# GET /experiences/check/slug
# Checks if slug is available
GET {{baseUrl}}/experiences/check/slug?slug=weekly-yoga-workshop-2025

###

### 7. Update Experience - Modify Schedule
# PATCH /experiences/:id
# Updates experience schedule (triggers event regeneration)
PATCH {{baseUrl}}/experiences/{{experienceId}}
Content-Type: application/json

{
  "schedules": [
    {
      "uid": "weekly-yoga-schedule",
      "recurringRule": [
        "DTSTART:20251201T140000",
        "RRULE:FREQ=WEEKLY;BYDAY=MO,WE,FR;COUNT=15"
      ],
      "startDate": "2025-12-01 02:00PM",
      "recurringType": "weekly"
    }
  ]
}

###

### 8. Update Experience - Add New Schedule
# PATCH /experiences/:id
# Adds a new schedule to existing experience
PATCH {{baseUrl}}/experiences/{{experienceId}}
Content-Type: application/json

{
  "schedules": [
    {
      "uid": "weekly-yoga-schedule",
      "recurringRule": [
        "DTSTART:20251201T100000",
        "RRULE:FREQ=WEEKLY;BYDAY=MO,WE,FR;COUNT=12"
      ],
      "startDate": "2025-12-01 10:00AM",
      "recurringType": "weekly"
    },
    {
      "uid": "weekend-yoga-schedule",
      "recurringRule": [
        "DTSTART:20251207T090000",
        "RRULE:FREQ=WEEKLY;BYDAY=SA,SU;COUNT=8"
      ],
      "startDate": "2025-12-07 09:00AM",
      "recurringType": "weekly"
    }
  ]
}

###

### 9. Update Experience - Remove All Schedules
# PATCH /experiences/:id
# Removes all schedules (soft deletes all events)
PATCH {{baseUrl}}/experiences/{{experienceId}}
Content-Type: application/json

{
  "schedules": []
}

###

### 10. Update Experience - Change Status
# PATCH /experiences/:id
# Updates experience status
PATCH {{baseUrl}}/experiences/{{experienceId}}
Content-Type: application/json

{
  "status": "DRAFTED"
}

###

### ==============================================
### Query ExperienceEvents (Direct MongoDB Check)
### These are for backend verification only
### ==============================================

### Note: Use MongoDB Compass or similar tool to query:
# 1. Find all active events for an experience:
#    db.experienceEvents.find({ experienceId: ObjectId("..."), status: "ACTIVE" })
#
# 2. Find deleted events:
#    db.experienceEvents.find({ experienceId: ObjectId("..."), status: "DELETED" })
#
# 3. Find locked events:
#    db.experienceEvents.find({ experienceId: ObjectId("..."), isLocked: true })
#
# 4. Count events by schedule:
#    db.experienceEvents.aggregate([
#      { $match: { experienceId: ObjectId("...") } },
#      { $group: { _id: "$scheduleId", count: { $sum: 1 } } }
#    ])

### ==============================================
### Testing Notes
### ==============================================

# After creating an experience:
# 1. Wait 1-2 seconds for background job to generate events
# 2. Check MongoDB for generated experienceEvents
# 3. Verify events have:
#    - experienceId: References created experience
#    - scheduleId: Matches schedule UID
#    - status: "ACTIVE" (default)
#    - isLocked: false (default)
#    - isRecurring: true (for recurring) or false (for single)
#
# Fields REMOVED from ExperienceEvent (now in Experience):
# - hubId ❌
# - title ❌
# - maximumCapacity ❌
# - normalSeat ❌
# - totalAvailableQty ❌
# - ticket[] ❌
# - ticketQty{} ❌
#
# New Status Management:
# - status: "ACTIVE" | "CANCELLED" | "DELETED" ✅
# - isLocked: boolean (separate concern) ✅
