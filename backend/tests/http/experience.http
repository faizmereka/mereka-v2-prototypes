### Variables
@baseUrl = http://localhost:3000/api/v1
@hubId = 6911c2e5a1bf597ffce83c8f
@userId = 6911c2e5a1bf597ffce83c90
@experienceId = replace-with-created-experience-id

### ==============================================
### Experience Endpoints - Test Updated Model
### ==============================================

### 1. Create Experience with Recurring Schedule (Weekly)
# POST /experiences
# Creates experience with weekly recurring events
POST {{baseUrl}}/experiences
Content-Type: application/json

{
  "experienceTitle": "Weekly Yoga Workshop",
  "slug": "weekly-yoga-workshop-2025",
  "experienceDescription": "Join our weekly yoga sessions for beginners and intermediate practitioners",
  "experienceType": "Virtual",
  "hubId": "{{hubId}}",
  "timeZone": "America/Los_Angeles",
  "meetingLink": "https://zoom.us/j/123456789",
  "primaryLanguage": "English",
  "audienceType": "Everyone",
  "maximumCapacity": 20,
  "experienceDuration": 3600000,
  "feePaidBy": "learner",
  "currency": "USD",
  "coverPhoto": "https://example.com/yoga-cover.jpg",
  "ticket": [
    {
      "id": "ticket1",
      "ticketType": "Paid",
      "ticketName": "Standard Ticket",
      "ticketPrice": 25,
      "ticketQty": 20,
      "hasCutoffTime": true,
      "cutoffNumber": 2,
      "cutoffTime": "hours",
      "cutoffBeforeAfter": "before",
      "description": "Early bird pricing"
    }
  ],
  "schedules": [
    {
      "uid": "weekly-yoga-schedule",
      "recurringRule": [
        "DTSTART:20251201T100000",
        "RRULE:FREQ=WEEKLY;BYDAY=MO,WE,FR;COUNT=12"
      ],
      "startDate": "2025-12-01 10:00AM",
      "recurringType": "weekly"
    }
  ],
  "status": "ACTIVE",
  "listingType": "platform",
  "createdBy": "{{userId}}"
}

