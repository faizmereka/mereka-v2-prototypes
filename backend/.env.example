# Application
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# MongoDB
MONGODB_URI=mongodb://localhost:27017/mereka_dev
MONGODB_TEST_URI=mongodb://localhost:27017/mereka_test

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-required-change-in-production
JWT_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# API
API_PREFIX=/api/v1

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Firebase Admin SDK (Get from Firebase Console -> Service Accounts)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Frontend URLs (Production)
AUTH_URL=https://auth.mereka.io
APP_URL=https://app.mereka.io
MEREKA_URL=https://mereka.io
CHECKOUT_URL=https://checkout.mereka.io

# Development URLs
DEV_AUTH_URL=http://localhost:4200
DEV_APP_URL=http://localhost:4200

# Cookie Domains (Production)
# COOKIE_DOMAIN: Used for cross-subdomain cookies across mereka.io, app.mereka.io, checkout.mereka.io
# ADMIN_COOKIE_DOMAIN: Used for admin.mereka.io (separate from main app)
# Leave empty for development (defaults to current host)
COOKIE_DOMAIN=.mereka.io
ADMIN_COOKIE_DOMAIN=.mereka.io

# Stripe Multi-Region Configuration
# Get these from Stripe Dashboard (https://dashboard.stripe.com/apikeys)

# Atlas/Global Stripe Account (default for non-Malaysian hubs)
STRIPE_ATLAS_SECRET_KEY=sk_test_REDACTED
STRIPE_ATLAS_WEBHOOK_SECRET=whsec_REDACTED
STRIPE_ATLAS_PUBLISHABLE_KEY=pk_test_REDACTED

# Malaysia Stripe Account (for Malaysian hubs)
# Create webhook in Stripe Dashboard: https://dashboard.stripe.com/webhooks
# Endpoint URL: https://api.mereka.io/api/v1/webhook?region=malaysia
STRIPE_MY_SECRET_KEY=sk_live_REDACTED
STRIPE_MY_WEBHOOK_SECRET=whsec_REDACTED
STRIPE_MY_PUBLISHABLE_KEY=pk_live_REDACTED
